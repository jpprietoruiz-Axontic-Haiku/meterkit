# --- apps/api ---
NODE_ENV=development
PORT=3000

# Postgres local (ver docker-compose.yml)
DATABASE_URL=postgres://meterkit:meterkit@localhost:5432/meterkit

# Secreto para firmar JWT. Generar uno propio, minimo 32 caracteres:
#   openssl rand -base64 32
JWT_SECRET=changeme-generate-a-real-32-char-secret

# Stripe (modo test). No se hardcodean claves reales en el repo.
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_TEST_SECRET_KEY
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_YOUR_STRIPE_WEBHOOK_SECRET
STRIPE_METERED_PRICE_ID=price_REPLACE_WITH_YOUR_METERED_PRICE_ID

# URL base del dashboard (apps/web), usada para redirects de Stripe Checkout/Portal
APP_BASE_URL=http://localhost:5173
